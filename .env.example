# ==========================================================
# Copy this file to ".env" and fill in real values.
# The real ".env" is git-ignored and must NOT be committed.
# ==========================================================

# --- IQAir AirVisual API ---
AIRVISUAL_API_KEY=your_iqair_api_key_here

# --- Locations to monitor (IQAir /v2/city endpoint) ---
# Format: city,state,country[,lat,lon]  —  multiple entries separated by ";"
AQ_LOCATIONS=Kigali,Kigali,Rwanda,-1.9499,30.0588;Delhi,Delhi,India,28.6667,77.1167

# --- How often the scheduler polls IQAir (minutes) ---
FETCH_INTERVAL_MINUTES=5

# --- Django core ---
SECRET_KEY=generate-a-new-secret-key
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# --- PostgreSQL connection (Guideline 3.3) ---
DB_NAME=air_quality_db
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=127.0.0.1
DB_PORT=5432
